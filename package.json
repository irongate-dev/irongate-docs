{
  "name": "irongate-docs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate-all.ts",
    "generate:errors": "tsx scripts/generate-error-docs.ts",
    "generate:env": "tsx scripts/generate-env-docs.ts",
    "generate:api": "tsx scripts/generate-api-docs.ts",
    "fetch:artifacts": "tsx scripts/fetch-artifacts.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/starlight": "^0.23.0",
    "astro": "^4.8.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "eslint-plugin-mdx": "^3.0.0",
    "eslint-plugin-n": "^17.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "tsx": "^4.0.0",
    "typescript": "5.4.x",
    "typescript-eslint": "^8.0.0"
  }
}
